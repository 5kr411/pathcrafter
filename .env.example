# Pathcrafter env template.
# Copy to .env (gitignored) and fill in. Shell exports with non-empty values
# override .env; empty/unset shell values fall through to .env.

# --- E2E ---

# Comma-separated Minecraft usernames to grant op on the e2e Docker server.
# `spawn_setup_bot` and `dev_observer` are always opped — add yours here if
# you want to run /commands when you join.
E2E_OPS=

# --- LLM agent layer ---
# Used by bots/agent_bot.ts and bots/agent_bot_runner.ts.

# Default provider + model. Can be overridden per-bot via CLI flag or
# roster entry (bots/agent_bot/runner/roster.ts).
AGENT_PROVIDER=anthropic
AGENT_MODEL=claude-sonnet-4-6

# Base URL override (for OpenAI-compat / local models). Leave unset for
# default cloud endpoints on anthropic / openai / gemini.
# AGENT_BASE_URL=http://localhost:11434/v1

# Optional API key for OpenAI-compat endpoints that require auth (some
# local servers don't). Named providers use their dedicated keys below.
# AGENT_API_KEY=

# --- Provider API keys ---
# Set the one matching your chosen provider. Dotenv loads these into
# process.env; never commit real values.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
